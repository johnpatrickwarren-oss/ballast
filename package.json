{
  "name": "@johnpatrickwarren-oss/ballast",
  "version": "0.0.1-pre",
  "description": "Capacity-forecast accountability: anytime-valid, gaming-resistant evidence-and-attribution layer for GPU reservations. Synthetic trace-grounded reference implementation. Consumes deploysignal-engine.",
  "license": "Apache-2.0",
  "private": true,
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsc -p tsconfig.test.json --noEmit",
    "pretest": "tsc -p tsconfig.test.json",
    "test": "node --test test/*.test.js",
    "typecheck": "tsc -p tsconfig.test.json --noEmit",
    "precoverage": "tsc -p tsconfig.test.json",
    "coverage": "node tools/coverage.js",
    "gate": "node ../sprag/arch.mjs check . --invariants arch-invariants.json --baseline-in arch-invariants.baseline.json"
  },
  "dependencies": {
    "@johnpatrickwarren-oss/deploysignal-engine": "file:../deploysignal-engine"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.4.0"
  }
}
